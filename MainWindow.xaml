<Window x:Class="BinaryCarver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BinaryCarver — Region Carving Workbench"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ TOP BAR ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <!-- Left: file info -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="BinaryCarver" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtFileName" Text="Drop a file to begin"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnBack" Content="◀ Back" Click="BtnBack_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Visibility="Collapsed"
                            ToolTip="Return to the parent file (navigate up from drill-in)"/>
                    <Button Content="Open File" Click="BtnOpen_Click"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <CheckBox x:Name="ChkRecursive" Content="Recursive"
                              VerticalAlignment="Center" Margin="0,0,12,0"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12" ToolTip="Scan inside carved regions for nested files"/>
                    <Button x:Name="BtnExtractSelected" Content="Extract Selected"
                            Click="BtnExtractSelected_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnExtractAll" Content="Extract All"
                            Click="BtnExtractAll_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnOpenInLens" Content="Open in BinaryLens"
                            Click="BtnOpenInLens_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Launch BinaryLens on the selected PE region"
                            Margin="0,0,8,0"/>
                    <Button Content="Signatures" Click="BtnSignatures_Click"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Manage custom file signatures"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnExport" Content="Export" Click="BtnExport_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Export region map (JSON, CSV, IDA, Ghidra, r2, BinaryNinja)"/>
                    <Button x:Name="BtnImportMap" Content="Import MAP" Click="BtnImportMap_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Import region map from IDA MAP, BinaryCarver JSON, or r2 script"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════ MAIN CONTENT ═══════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>          <!-- 0: byte map + entropy -->
                <RowDefinition Height="*" MinHeight="80"/> <!-- 1: region grid -->
                <RowDefinition Height="5"/>              <!-- 2: splitter -->
                <RowDefinition Height="200" MinHeight="100"/> <!-- 3: bottom panel area -->
            </Grid.RowDefinitions>

            <!-- ── Drop zone (shown when no file loaded) ── -->
            <Border x:Name="DropZone" Grid.Row="0" Grid.RowSpan="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="2" CornerRadius="12"
                    Margin="40,40" Padding="40"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x2193;" FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Drop any binary file here" FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="EXE, DLL, firmware, disk images, memory dumps..."
                               FontSize="13" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- ── Visual byte map + entropy heatmap ── -->
            <Border x:Name="ByteMapPanel" Grid.Row="0" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="FILE MAP"/>
                    <Canvas x:Name="ByteMapCanvas" Height="40"
                            Background="{StaticResource BackgroundBrush}"
                            ClipToBounds="True"/>
                    <!-- Legend -->
                    <WrapPanel Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="PE/EXE" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Width="12" Height="12" Background="#2196F3" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Archive" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Width="12" Height="12" Background="#FF9800" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Image" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Width="12" Height="12" Background="#9C27B0" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Document" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Width="12" Height="12" Background="#F44336" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Overlay" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="12" Height="12" Background="#607D8B" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Other" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <!-- Gap classification colors -->
                        <TextBlock Text="  |  Gaps:" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,8,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,4,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#333333"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="Pad" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Border Width="12" Height="12" Background="#5C6BC0" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Text" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Border Width="12" Height="12" Background="#26A69A" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Code" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Border Width="12" Height="12" Background="#EF5350" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Cmprs" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Border Width="12" Height="12" Background="#AB47BC" CornerRadius="2" Margin="0,0,4,0"/>
                            <TextBlock Text="Struct" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </WrapPanel>

                    <!-- ── Visualization settings bar ── -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="4"
                            Padding="8,4" Margin="0,8,0,4">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Block Size:" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                            <ComboBox x:Name="CboBlockSize" Width="70" FontSize="10"
                                      SelectedIndex="2"
                                      SelectionChanged="CboBlockSize_Changed">
                                <ComboBoxItem Content="256"/>
                                <ComboBoxItem Content="512"/>
                                <ComboBoxItem Content="1024"/>
                                <ComboBoxItem Content="2048"/>
                                <ComboBoxItem Content="4096"/>
                                <ComboBoxItem Content="8192"/>
                            </ComboBox>
                            <TextBlock Text="  Color:" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,4,0"/>
                            <ComboBox x:Name="CboColorMode" Width="105" FontSize="10"
                                      SelectedIndex="0"
                                      SelectionChanged="CboColorMode_Changed">
                                <ComboBoxItem Content="Byte Entropy"/>
                                <ComboBoxItem Content="Nibble Entropy"/>
                                <ComboBoxItem Content="Bit Entropy"/>
                                <ComboBoxItem Content="Bigram Entropy"/>
                                <ComboBoxItem Content="Divergence"/>
                                <ComboBoxItem Content="Delta"/>
                                <ComboBoxItem Content="Region Type"/>
                                <ComboBoxItem Content="Gap Class"/>
                            </ComboBox>
                            <TextBlock Text="  3D Shape:" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,4,0"/>
                            <ComboBox x:Name="Cbo3DShape" Width="80" FontSize="10"
                                      SelectedIndex="0"
                                      SelectionChanged="Cbo3DShape_Changed">
                                <ComboBoxItem Content="Cubes"/>
                                <ComboBoxItem Content="Bars"/>
                                <ComboBoxItem Content="Spheres"/>
                            </ComboBox>
                            <Button x:Name="Btn3DToggle" Content="Hide 3D"
                                    Click="Btn3DToggle_Click"
                                    Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"
                                    FontSize="10"/>
                        </WrapPanel>
                    </Border>

                    <!-- Multi-base entropy heatmaps -->
                    <TextBlock Style="{StaticResource SectionHeader}" Text="MULTI-BASE ENTROPY"
                               Margin="0,0,0,0"/>

                    <!-- Byte entropy (base-256) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Byte" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="EntropyCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Byte entropy (base-256): 0–8 bits"/>
                    </DockPanel>

                    <!-- Nibble entropy (base-16) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Nibble" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="NibbleEntropyCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Nibble entropy (base-16): 0–4 bits. Reveals hex-structured data"/>
                    </DockPanel>

                    <!-- Bit entropy (base-2) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Bit" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="BitEntropyCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Bit entropy (base-2): 0–1 bit. Reveals bit-bias and fill patterns"/>
                    </DockPanel>

                    <!-- Bigram entropy (byte pairs) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Bigram" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="BigramEntropyCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Bigram entropy (byte pairs): 0–16 bits. Captures sequential structure"/>
                    </DockPanel>

                    <!-- Divergence (cross-base boundary detector) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Diverg." FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource WarningBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="DivergenceCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Cross-base divergence: bright = bases disagree = likely structural boundary"/>
                    </DockPanel>

                    <!-- Delta entropy (rate of change — boundary detector) -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock Text="Delta" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="DeltaEntropyCanvas" Height="16"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Delta entropy: rate of change between blocks. Spikes = boundaries."/>
                    </DockPanel>

                    <!-- Legend -->
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="Low" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Border Width="80" Height="10" Margin="4,1,4,0" CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#2196F3" Offset="0"/>
                                    <GradientStop Color="#4CAF50" Offset="0.25"/>
                                    <GradientStop Color="#FFEB3B" Offset="0.5"/>
                                    <GradientStop Color="#FF9800" Offset="0.75"/>
                                    <GradientStop Color="#F44336" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="High" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                        <TextBlock Text="Divergence:" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Border Width="60" Height="10" Margin="4,1,4,0" CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#1A1A1A" Offset="0"/>
                                    <GradientStop Color="#FF6F00" Offset="0.5"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Boundary" FontSize="9"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </WrapPanel>

                </StackPanel>
            </Border>

            <!-- ── Region grid + 3D view side by side ── -->
            <Grid x:Name="ResultsPanel" Grid.Row="1" Visibility="Collapsed"
                  Margin="16,8,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition x:Name="Col3D" Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Left: region grid -->
                <DockPanel Grid.Column="0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock x:Name="TxtSummary"
                                   Style="{StaticResource SectionHeader}"
                                   Text="CARVED REGIONS" DockPanel.Dock="Left"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock x:Name="TxtOverlay"
                                       FontSize="11" Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="TxtRegionCount"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="GridRegions"
                              AutoGenerateColumns="False"
                              SelectionChanged="GridRegions_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=""          Binding="{Binding Icon}"          Width="30"/>
                            <DataGridTextColumn Header="#"          Binding="{Binding Index}"         Width="35"/>
                            <DataGridTextColumn Header="Type"       Binding="{Binding DisplayType}"   Width="120"/>
                            <DataGridTextColumn Header="Offset"     Binding="{Binding OffsetHex}"     Width="100"/>
                            <DataGridTextColumn Header="Size"       Binding="{Binding SizeDisplay}"   Width="80"/>
                            <DataGridTextColumn Header="Entropy"    Binding="{Binding EntropyDisplay}" Width="60"/>
                            <DataGridTextColumn Header="Depth"      Binding="{Binding Depth}"         Width="45"/>
                            <DataGridTextColumn Header="Conf."      Binding="{Binding ConfidenceDisplay}" Width="55"/>
                            <DataGridTextColumn Header="Sized By"   Binding="{Binding SizingMethod}"  Width="65"/>
                            <DataGridTextColumn Header="Signature"  Binding="{Binding Signature}"     Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Vertical splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <!-- Right: 3D data visualization (always visible) -->
                <Border x:Name="Panel3D" Grid.Column="2"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Margin="4,0,0,0">
                    <Grid>
                        <Viewport3D x:Name="Viewport3D" ClipToBounds="True">
                            <Viewport3D.Camera>
                                <PerspectiveCamera x:Name="Camera3D"
                                    Position="5,5,12" LookDirection="-0.3,-0.3,-1"
                                    UpDirection="0,1,0" FieldOfView="60"/>
                            </Viewport3D.Camera>
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <Model3DGroup>
                                        <AmbientLight Color="#404040"/>
                                        <DirectionalLight Color="#C0C0C0" Direction="-1,-1,-1"/>
                                        <DirectionalLight Color="#606060" Direction="1,0.5,0.5"/>
                                    </Model3DGroup>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                            <ModelVisual3D x:Name="DataModel3D"/>
                            <ModelVisual3D x:Name="HighlightModel3D"/>
                        </Viewport3D>
                        <TextBlock x:Name="Txt3DInfo" FontSize="10" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   Margin="8,0,0,4"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Splitter ── -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Margin="0"/>

            <!-- ═══ BOTTOM PANEL AREA ═══ -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel>

            <!-- ── Detail / Hex preview panel ── -->
            <Border x:Name="DetailPanel" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: region info -->
                    <StackPanel Grid.Column="0">
                        <DockPanel>
                            <TextBlock x:Name="TxtDetailHeader"
                                       Style="{StaticResource SectionHeader}" Text="REGION DETAIL"
                                       DockPanel.Dock="Left"/>
                            <Button x:Name="BtnDrillIn" Content="Drill In"
                                    Click="BtnDrillIn_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    ToolTip="Analyze this region as its own file — run full carving engine on the selected data"/>
                        </DockPanel>
                        <DataGrid x:Name="GridDetail"
                                  AutoGenerateColumns="False"
                                  MaxHeight="160"
                                  Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="120"/>
                                <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Right: hex preview -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="HEX PREVIEW"/>
                        <TextBox x:Name="TxtHexPreview"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="8,4"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 MaxHeight="160"
                                 AcceptsReturn="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Entropy block inspector (shown when clicking entropy tracks) ── -->
            <Border x:Name="BlockInspectorPanel" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ENTROPY BLOCK INSPECTOR"/>
                    <!-- Block info + action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="TxtBlockInfo" FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="TxtBlockEntropy" FontFamily="Consolas" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Selection range display (shown when shift-clicking a range) -->
                    <TextBlock x:Name="TxtBlockRange" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource WarningBrush}" Margin="0,2,0,0"
                               Visibility="Collapsed"/>
                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Extract Block" Click="BtnExtractBlock_Click"
                                Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Extract to Boundary" Click="BtnExtractToBoundary_Click"
                                Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                ToolTip="Extract from this block to the next divergence peak"/>
                        <Button Content="Drill In" Click="BtnDrillInBlock_Click"
                                Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                ToolTip="Analyze this data range with the full carving engine"/>
                        <Button Content="Drill In Range" Click="BtnDrillInRange_Click"
                                Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                                x:Name="BtnDrillInRange" IsEnabled="False"
                                ToolTip="Shift-click another block to select a range, then drill in"/>
                        <Button Content="Close" Click="BtnCloseInspector_Click"
                                Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <!-- Hex preview of the block -->
                    <TextBox x:Name="TxtBlockHexPreview"
                             FontFamily="Consolas" FontSize="10"
                             IsReadOnly="True"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="6,3"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             MaxHeight="100"
                             Margin="0,6,0,0"
                             AcceptsReturn="True"/>
                </StackPanel>
            </Border>

            <!-- ── Custom range extraction panel (always visible when file loaded) ── -->
            <Border x:Name="RangePanel" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="CUSTOM RANGE EXTRACTION"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Offset:" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtRangeOffset" Width="120" FontFamily="Consolas"
                                 FontSize="12" Padding="4,3" ToolTip="Hex (0x...) or decimal"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"/>
                        <TextBlock Text="Size:" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,6,0"/>
                        <TextBox x:Name="TxtRangeSize" Width="120" FontFamily="Consolas"
                                 FontSize="12" Padding="4,3" ToolTip="Hex (0x...) or decimal"
                                 Background="{StaticResource BackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"/>
                        <Button Content="Extract Range" Click="BtnExtractRange_Click"
                                Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

                </StackPanel>
            </ScrollViewer>
            <!-- ═══ END BOTTOM PANEL AREA ═══ -->

        </Grid>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtFileInfo" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
