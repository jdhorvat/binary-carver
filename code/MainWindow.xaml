<Window x:Class="BinaryCarver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BinaryCarver — Region Carving Workbench"
        Width="1400" Height="800"
        MinWidth="900" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ TOP BAR ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel>
                <!-- Left: file info -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="BinaryCarver" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TxtFileName" Text="Drop a file to begin"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnBack" Content="◀ Back" Click="BtnBack_Click"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Visibility="Collapsed"
                            ToolTip="Return to the parent file (navigate up from drill-in)"/>
                    <Button Content="Open File" Click="BtnOpen_Click"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <CheckBox x:Name="ChkRecursive" Content="Recursive"
                              VerticalAlignment="Center" Margin="0,0,12,0"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontSize="12" ToolTip="Scan inside carved regions for nested files"/>
                    <Button x:Name="BtnExtractSelected" Content="Extract Selected"
                            Click="BtnExtractSelected_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnExtractAll" Content="Extract All"
                            Click="BtnExtractAll_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnOpenInLens" Content="Open in BinaryLens"
                            Click="BtnOpenInLens_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Launch BinaryLens on the selected PE region"
                            Margin="0,0,8,0"/>
                    <Button Content="Signatures" Click="BtnSignatures_Click"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Manage custom file signatures"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnExport" Content="Export" Click="BtnExport_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Export region map (JSON, CSV, IDA, Ghidra, r2, BinaryNinja)"/>
                    <Button x:Name="BtnImportMap" Content="Import MAP" Click="BtnImportMap_Click"
                            Style="{StaticResource SecondaryButton}" IsEnabled="False"
                            ToolTip="Import region map from IDA MAP, BinaryCarver JSON, or r2 script"
                            Margin="8,0,0,0"/>
                    <Button x:Name="BtnExportReport" Content="Export Report"
                            Click="BtnExportReport_Click"
                            Style="{StaticResource PrimaryButton}" IsEnabled="False"
                            ToolTip="Export all visualizations + HTML report for file, carved regions, manual regions, and current selection"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════ MAIN CONTENT ═══════ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>             <!-- 0: controls + byte map bar -->
                <RowDefinition Height="*" MinHeight="200"/> <!-- 1: main 3-column area -->
                <RowDefinition Height="Auto"/>             <!-- 2: entropy bars (bottom) -->
            </Grid.RowDefinitions>

            <!-- ── Drop zone (shown when no file loaded) ── -->
            <Border x:Name="DropZone" Grid.Row="0" Grid.RowSpan="3"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="2" CornerRadius="12"
                    Margin="40,40" Padding="40"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x2193;" FontSize="48"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Drop any binary file here" FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="EXE, DLL, firmware, disk images, memory dumps..."
                               FontSize="13" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- ── Visual byte map (top) ── -->
            <Border x:Name="ByteMapPanel" Grid.Row="0" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <StackPanel>

                    <!-- ── Row 1: color legend (single compact line) ── -->
                    <DockPanel Margin="0,0,0,3" LastChildFill="False">
                        <!-- Left: swatch-only legend (hover for name, no text labels) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="10" Height="10" Background="#4CAF50" CornerRadius="1" Margin="0,0,3,0" ToolTip="PE/EXE"/>
                            <Border Width="10" Height="10" Background="#2196F3" CornerRadius="1" Margin="0,0,3,0" ToolTip="Archive"/>
                            <Border Width="10" Height="10" Background="#FF9800" CornerRadius="1" Margin="0,0,3,0" ToolTip="Image"/>
                            <Border Width="10" Height="10" Background="#9C27B0" CornerRadius="1" Margin="0,0,3,0" ToolTip="Document"/>
                            <Border Width="10" Height="10" Background="#F44336" CornerRadius="1" Margin="0,0,3,0" ToolTip="Overlay"/>
                            <Border Width="10" Height="10" Background="#607D8B" CornerRadius="1" Margin="0,0,8,0" ToolTip="Other"/>
                            <TextBlock Text="|" FontSize="9" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                            <Border Width="10" Height="10" CornerRadius="1" Margin="0,0,3,0" ToolTip="Gap: Padding">
                                <Border.Background><SolidColorBrush Color="#333333"/></Border.Background>
                            </Border>
                            <Border Width="10" Height="10" Background="#5C6BC0" CornerRadius="1" Margin="0,0,3,0" ToolTip="Gap: Text"/>
                            <Border Width="10" Height="10" Background="#26A69A" CornerRadius="1" Margin="0,0,3,0" ToolTip="Gap: Code"/>
                            <Border Width="10" Height="10" Background="#EF5350" CornerRadius="1" Margin="0,0,3,0" ToolTip="Gap: Compressed"/>
                            <Border Width="10" Height="10" Background="#AB47BC" CornerRadius="1" ToolTip="Gap: Structured"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- ── Row 2: byte map bar (full width) ── -->
                    <Canvas x:Name="ByteMapCanvas" Height="28"
                            Background="{StaticResource BackgroundBrush}"
                            ClipToBounds="True"
                            ToolTip="File map — click to inspect, hover for region info"/>

                </StackPanel>
            </Border>

            <!-- ── Entropy bars (bottom of window) ── -->
            <Border x:Name="EntropyBarsPanel" Grid.Row="2" Visibility="Collapsed"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,3">
                <StackPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Byte" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="EntropyCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Byte entropy (base-256): 0–8 bits"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Nibble" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="NibbleEntropyCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Nibble entropy (base-16): 0–4 bits. Reveals hex-structured data"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Bit" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="BitEntropyCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Bit entropy (base-2): 0–1 bit. Reveals bit-bias and fill patterns"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Bigram" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="BigramEntropyCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Bigram entropy (byte pairs): 0–16 bits. Captures sequential structure"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Diverg." FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource WarningBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="DivergenceCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Cross-base divergence: bright = bases disagree = structural boundary"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <TextBlock Text="Delta" FontSize="9" Width="42" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}" DockPanel.Dock="Left"/>
                        <Canvas x:Name="DeltaEntropyCanvas" Height="15"
                                Background="{StaticResource BackgroundBrush}" ClipToBounds="True"
                                ToolTip="Delta entropy: rate of change between blocks. Spikes = boundaries."/>
                    </DockPanel>
                    <!-- Compact inline gradient legend -->
                    <StackPanel Orientation="Horizontal" Margin="42,3,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Lo" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Border Width="64" Height="8" Margin="3,0,3,0" CornerRadius="1" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#2196F3" Offset="0"/>
                                    <GradientStop Color="#4CAF50" Offset="0.25"/>
                                    <GradientStop Color="#FFEB3B" Offset="0.5"/>
                                    <GradientStop Color="#FF9800" Offset="0.75"/>
                                    <GradientStop Color="#F44336" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Hi" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="Diverg:" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Border Width="48" Height="8" Margin="3,0,3,0" CornerRadius="1" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#1A1A1A" Offset="0"/>
                                    <GradientStop Color="#FF6F00" Offset="0.5"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="→Bndry" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Main 3-column layout: Left panels | 3D | Byte-pair plot ── -->
            <Grid x:Name="ResultsPanel" Grid.Row="1" Visibility="Collapsed"
                  Margin="8,4,8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 0: shared Block/Color controls strip -->
                    <RowDefinition Height="*"/>      <!-- 1: main 3-column content -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="180"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition x:Name="Col3D" Width="1*" MinWidth="180"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="1*" MinWidth="180"/>
                </Grid.ColumnDefinitions>

                <!-- ── Row 0: Block Size + Color Mode controls (spans 3D + 2D columns) ── -->
                <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="6,3" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Block:" FontSize="9" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                        <ComboBox x:Name="CboBlockSize" Width="58" FontSize="9"
                                  SelectedIndex="0" SelectionChanged="CboBlockSize_Changed">
                            <ComboBoxItem Content="64"/>
                            <ComboBoxItem Content="128"/>
                            <ComboBoxItem Content="256"/>
                            <ComboBoxItem Content="512"/>
                            <ComboBoxItem Content="1024"/>
                            <ComboBoxItem Content="2048"/>
                            <ComboBoxItem Content="4096"/>
                            <ComboBoxItem Content="8192"/>
                        </ComboBox>
                        <TextBlock Text="Color:" FontSize="9" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,3,0"/>
                        <ComboBox x:Name="CboColorMode" Width="95" FontSize="9"
                                  SelectedIndex="0" SelectionChanged="CboColorMode_Changed">
                            <ComboBoxItem Content="Byte Entropy"/>
                            <ComboBoxItem Content="Nibble Entropy"/>
                            <ComboBoxItem Content="Bit Entropy"/>
                            <ComboBoxItem Content="Bigram Entropy"/>
                            <ComboBoxItem Content="Divergence"/>
                            <ComboBoxItem Content="Delta"/>
                            <ComboBoxItem Content="Region Type"/>
                            <ComboBoxItem Content="Gap Class"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ════ LEFT COLUMN: Carved Regions + Manual Regions + Panels ════ -->
                <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="60"/>    <!-- Carved Regions -->
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="2*" MinHeight="50"/>    <!-- Manual Regions -->
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="5*" MinHeight="100"/>   <!-- Range/Detail/Inspector (largest) -->
                    </Grid.RowDefinitions>

                    <!-- Carved Regions -->
                    <DockPanel Grid.Row="0">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock x:Name="TxtSummary"
                                       Style="{StaticResource SectionHeader}"
                                       Text="CARVED REGIONS" DockPanel.Dock="Left"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtOverlay"
                                           FontSize="11" Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtRegionCount"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <DataGrid x:Name="GridRegions"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="GridRegions_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header=""         Binding="{Binding Icon}"              Width="26"/>
                                <DataGridTextColumn Header="#"         Binding="{Binding Index}"             Width="30"/>
                                <DataGridTextColumn Header="Type"      Binding="{Binding DisplayType}"       Width="*"/>
                                <DataGridTextColumn Header="Offset"    Binding="{Binding OffsetHex}"         Width="90"/>
                                <DataGridTextColumn Header="Size"      Binding="{Binding SizeDisplay}"       Width="70"/>
                                <DataGridTextColumn Header="Ent."      Binding="{Binding EntropyDisplay}"    Width="44"/>
                                <DataGridTextColumn Header="Conf."     Binding="{Binding ConfidenceDisplay}" Width="46"/>
                                <DataGridTextColumn Header="By"        Binding="{Binding SizingMethod}"      Width="52"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"/>

                    <!-- Manual Regions -->
                    <Border Grid.Row="2"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <DockPanel Margin="0,4,0,0">
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,3">
                                <TextBlock Text="MANUAL REGIONS" Style="{StaticResource SectionHeader}"
                                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button x:Name="BtnExportManualRegions" Content="Export"
                                            Click="BtnExportManualRegions_Click"
                                            Style="{StaticResource SecondaryButton}" FontSize="9"
                                            Padding="6,2" IsEnabled="False" Margin="0,0,4,0"
                                            ToolTip="Export manual regions to JSON, CSV, or analysis tool script"/>
                                    <Button x:Name="BtnImportManualRegions" Content="Import"
                                            Click="BtnImportManualRegions_Click"
                                            Style="{StaticResource SecondaryButton}" FontSize="9"
                                            Padding="6,2"
                                            ToolTip="Import manual regions from JSON"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid x:Name="GridManualRegions"
                                      AutoGenerateColumns="False"
                                      SelectionChanged="GridManualRegions_SelectionChanged"
                                      FontSize="11" CanUserAddRows="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Color"  Binding="{Binding ColorHex}"          Width="46" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Name"   Binding="{Binding Name}"              Width="*"/>
                                    <DataGridTextColumn Header="Blocks" Binding="{Binding BlockCountDisplay}"  Width="52" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Notes"  Binding="{Binding Notes}"             Width="70"/>
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Highlight in 3D" Click="ManualRegion_Highlight_Click"/>
                                        <MenuItem Header="Remove Selected Blocks" Click="ManualRegion_RemoveBlocks_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Rename" Click="ManualRegion_Rename_Click"/>
                                        <MenuItem Header="Delete Region" Click="ManualRegion_Delete_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"/>

                    <!-- Range / Detail / Inspector panels stacked at bottom -->
                    <DockPanel Grid.Row="4" LastChildFill="True">

                            <!-- Custom Range Extraction -->
                            <Border x:Name="RangePanel" DockPanel.Dock="Top" Visibility="Collapsed"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0" Padding="8,5">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="CUSTOM RANGE EXTRACTION"/>
                                    <WrapPanel>
                                        <TextBlock Text="Offset:" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                        <TextBox x:Name="TxtRangeOffset" Width="100" FontFamily="Consolas"
                                                 FontSize="11" Padding="4,2" ToolTip="Hex (0x...) or decimal"
                                                 Background="{StaticResource BackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"/>
                                        <TextBlock Text="Size:" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="10,0,4,0"/>
                                        <TextBox x:Name="TxtRangeSize" Width="100" FontFamily="Consolas"
                                                 FontSize="11" Padding="4,2" ToolTip="Hex (0x...) or decimal"
                                                 Background="{StaticResource BackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}"/>
                                        <Button Content="Extract Range" Click="BtnExtractRange_Click"
                                                Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                                FontSize="11" Padding="8,3"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Region Detail panel -->
                            <Border x:Name="DetailPanel" DockPanel.Dock="Top" Visibility="Collapsed"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0" Padding="8,5">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,3">
                                        <TextBlock x:Name="TxtDetailHeader"
                                                   Style="{StaticResource SectionHeader}" Text="REGION DETAIL"
                                                   DockPanel.Dock="Left"/>
                                        <Button x:Name="BtnDrillIn" Content="Drill In"
                                                Click="BtnDrillIn_Click"
                                                Style="{StaticResource SecondaryButton}"
                                                DockPanel.Dock="Right" FontSize="10" Padding="8,3"
                                                ToolTip="Analyze this region as its own file"/>
                                    </DockPanel>
                                    <DataGrid x:Name="GridDetail" AutoGenerateColumns="False" MaxHeight="130">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Property" Binding="{Binding Key}"   Width="110"/>
                                            <DataGridTextColumn Header="Value"    Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="HEX PREVIEW" Margin="0,5,0,0"/>
                                    <TextBox x:Name="TxtHexPreview"
                                             FontFamily="Consolas" FontSize="10" IsReadOnly="True"
                                             Background="{StaticResource BackgroundBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                             Padding="6,3" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" MaxHeight="120" AcceptsReturn="True"/>
                                </StackPanel>
                            </Border>

                            <!-- Entropy Block Inspector (fills remaining space) -->
                            <Border x:Name="BlockInspectorPanel" Visibility="Collapsed"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0" Padding="8,5">
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}" Text="BLOCK INSPECTOR"/>
                                    <TextBlock DockPanel.Dock="Top" x:Name="TxtBlockInfo" FontFamily="Consolas" FontSize="10"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                    <TextBlock DockPanel.Dock="Top" x:Name="TxtBlockEntropy" FontFamily="Consolas" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"
                                               TextWrapping="Wrap"/>
                                    <TextBlock DockPanel.Dock="Top" x:Name="TxtBlockRange" FontFamily="Consolas" FontSize="10"
                                               Foreground="{StaticResource WarningBrush}" Margin="0,2,0,0"
                                               Visibility="Collapsed"/>
                                    <WrapPanel DockPanel.Dock="Top" Margin="0,5,0,0">
                                        <Button Content="Extract Block" Click="BtnExtractBlock_Click"
                                                Style="{StaticResource SecondaryButton}" FontSize="10" Padding="6,3"/>
                                        <Button Content="To Boundary" Click="BtnExtractToBoundary_Click"
                                                Style="{StaticResource SecondaryButton}" Margin="4,0,0,0"
                                                FontSize="10" Padding="6,3"
                                                ToolTip="Extract from this block to the next divergence peak"/>
                                        <Button Content="Drill In" Click="BtnDrillInBlock_Click"
                                                Style="{StaticResource PrimaryButton}" Margin="4,0,0,0"
                                                FontSize="10" Padding="6,3"/>
                                        <Button Content="Drill Range" Click="BtnDrillInRange_Click"
                                                Style="{StaticResource PrimaryButton}" Margin="4,0,0,0"
                                                x:Name="BtnDrillInRange" IsEnabled="False"
                                                FontSize="10" Padding="6,3"
                                                ToolTip="Shift-click another block to select a range, then drill in"/>
                                        <Button Content="Close" Click="BtnCloseInspector_Click"
                                                Style="{StaticResource SecondaryButton}" Margin="4,0,0,0"
                                                FontSize="10" Padding="6,3"/>
                                    </WrapPanel>
                                    <!-- Hex preview fills all remaining space -->
                                    <TextBox x:Name="TxtBlockHexPreview"
                                             FontFamily="Consolas" FontSize="9" IsReadOnly="True"
                                             Background="{StaticResource BackgroundBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                             Padding="5,3" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" Margin="0,5,0,0"
                                             AcceptsReturn="True"/>
                                </DockPanel>
                            </Border>

                    </DockPanel>
                </Grid>

                <!-- Column Splitter: Left ↔ 3D -->
                <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <!-- ════ CENTER COLUMN: 3D View ════ -->
                <Border x:Name="Panel3D" Grid.Row="1" Grid.Column="2"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <DockPanel LastChildFill="True">
                        <!-- 3D Controls toolbar — wraps to multiple lines -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="6,4">
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Layout mode -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                                    <TextBlock Text="Layout:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <ComboBox x:Name="Cbo3DLayout" Width="95" FontSize="10"
                                              SelectedIndex="0" SelectionChanged="Cbo3DLayout_Changed"
                                              ToolTip="3D layout mode — how blocks are arranged in space">
                                        <ComboBoxItem Content="Auto Cube"/>
                                        <ComboBoxItem Content="Wrap Grid"/>
                                        <ComboBoxItem Content="Flat Grid"/>
                                        <ComboBoxItem Content="HCP Spheres"/>
                                        <ComboBoxItem Content="Voxel Vol"/>
                                    </ComboBox>
                                </StackPanel>
                                <!-- Shape -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                                    <TextBlock Text="Shape:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <ComboBox x:Name="Cbo3DShape" Width="72" FontSize="10"
                                              SelectedIndex="0" SelectionChanged="Cbo3DShape_Changed">
                                        <ComboBoxItem Content="Cubes"/>
                                        <ComboBoxItem Content="Bars"/>
                                        <ComboBoxItem Content="Spheres"/>
                                    </ComboBox>
                                </StackPanel>
                                <!-- Spread -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                                    <TextBlock Text="Spread:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <Slider x:Name="SliderSpacing" Width="70" Minimum="1.1" Maximum="4.0"
                                            Value="1.1" VerticalAlignment="Center"
                                            SmallChange="0.1" LargeChange="0.5"
                                            TickFrequency="0.1" IsSnapToTickEnabled="False"
                                            ValueChanged="SliderSpacing_Changed"
                                            ToolTip="Spread blocks apart in 3D view"/>
                                    <TextBlock x:Name="TxtSpacingValue" Text="1.1" FontSize="10" Width="22"
                                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="3,0,0,0"/>
                                </StackPanel>
                                <!-- Wrap W/H (shown for Wrap Grid, Flat Grid, HCP) -->
                                <StackPanel x:Name="Panel3DWrap" Orientation="Horizontal" Visibility="Collapsed" Margin="0,2,10,2">
                                    <TextBlock Text="W:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                    <Slider x:Name="Slider3DWrapW" Width="65" Minimum="1" Maximum="256"
                                            Value="16" IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"
                                            ValueChanged="Slider3DWrapW_Changed"
                                            ToolTip="3D wrap width (columns)"/>
                                    <TextBlock x:Name="Txt3DWrapW" Text="16" FontSize="10" Width="24"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="3,0,8,0"/>
                                    <TextBlock Text="H:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                    <Slider x:Name="Slider3DWrapH" Width="65" Minimum="1" Maximum="256"
                                            Value="16" IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"
                                            ValueChanged="Slider3DWrapH_Changed"
                                            ToolTip="3D wrap height (rows)"/>
                                    <TextBlock x:Name="Txt3DWrapH" Text="16" FontSize="10" Width="24"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </StackPanel>
                                <!-- Voxel dimension (shown for Voxel Vol) -->
                                <StackPanel x:Name="Panel3DVoxel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,2,10,2">
                                    <TextBlock Text="Dim:" FontSize="10" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                    <Slider x:Name="Slider3DVoxelDim" Width="75" Minimum="16" Maximum="256"
                                            Value="64" IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"
                                            ValueChanged="Slider3DVoxelDim_Changed"
                                            ToolTip="Voxel cube dimension (D×D×D)"/>
                                    <TextBlock x:Name="Txt3DVoxelDim" Text="64" FontSize="10" Width="28"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <!-- 3D Viewport fills remaining space -->
                        <Grid>
                            <Viewport3D x:Name="Viewport3D" ClipToBounds="True">
                                <Viewport3D.Camera>
                                    <PerspectiveCamera x:Name="Camera3D"
                                        Position="5,5,12" LookDirection="-0.3,-0.3,-1"
                                        UpDirection="0,1,0" FieldOfView="60"/>
                                </Viewport3D.Camera>
                                <ModelVisual3D>
                                    <ModelVisual3D.Content>
                                        <Model3DGroup>
                                            <AmbientLight Color="#404040"/>
                                            <DirectionalLight Color="#C0C0C0" Direction="-1,-1,-1"/>
                                            <DirectionalLight Color="#606060" Direction="1,0.5,0.5"/>
                                        </Model3DGroup>
                                    </ModelVisual3D.Content>
                                </ModelVisual3D>
                                <ModelVisual3D x:Name="DataModel3D"/>
                                <ModelVisual3D x:Name="HighlightModel3D"/>
                            </Viewport3D>
                            <TextBlock x:Name="Txt3DInfo" FontSize="12" FontFamily="Consolas"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       TextWrapping="Wrap" MaxWidth="400"
                                       Margin="8,0,0,6"/>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Column Splitter: 3D ↔ Dot plot -->
                <GridSplitter Grid.Row="1" Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <!-- ════ RIGHT COLUMN: 2D Visualizations ════ -->
                <Grid Grid.Row="1" Grid.Column="4" Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header — mode selector + zoom hint -->
                    <DockPanel Grid.Row="0" Margin="8,5,8,3">
                        <ComboBox x:Name="CboPlotMode" DockPanel.Dock="Left"
                                  FontSize="9" Width="160" VerticalAlignment="Center"
                                  SelectionChanged="CboPlotMode_Changed" SelectedIndex="0">
                            <ComboBoxItem Content="⊞  All Views"/>
                            <ComboBoxItem Content="Byte-Pair Plot"/>
                            <ComboBoxItem Content="Byte Histogram"/>
                            <ComboBoxItem Content="Position Heat Map"/>
                            <ComboBoxItem Content="Entropy Waveform"/>
                            <ComboBoxItem Content="Parallel Coordinates"/>
                            <ComboBoxItem Content="RadViz"/>
                            <ComboBoxItem Content="Autocorrelation"/>
                            <ComboBoxItem Content="Byte Presence"/>
                        </ComboBox>
                        <TextBlock x:Name="TxtPlotHint"
                                   Text="scroll=zoom  drag=pan  mid-click=fit  Esc=clear"
                                   FontSize="8" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="6,0,0,0"/>
                    </DockPanel>

                    <!-- Row 1: Parameter strip — visualization adjustments -->
                    <Border x:Name="ParamStrip" Grid.Row="1" Visibility="Collapsed"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Margin="4,0,4,0" Padding="6,3">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Wrap Width (universal: controls fold period) -->
                            <TextBlock Text="Wrap:" FontSize="8" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                            <Slider x:Name="SliderWrapWidth" Width="90" Minimum="1" Maximum="8192"
                                    Value="256" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    ValueChanged="SliderWrapWidth_Changed"
                                    ToolTip="Fold/wrap width — the period at which data wraps to next row"/>
                            <TextBlock x:Name="TxtWrapWidth" Text="256" FontSize="8" Width="32"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="3,0,8,0"/>

                            <!-- Stride (byte-pair plot: gap between paired bytes) -->
                            <StackPanel x:Name="PanelStride" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Stride:" FontSize="8" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                <Slider x:Name="SliderStride" Width="70" Minimum="1" Maximum="512"
                                        Value="1" IsSnapToTickEnabled="False"
                                        VerticalAlignment="Center"
                                        ValueChanged="SliderStride_Changed"
                                        ToolTip="Byte-pair stride — gap between the two bytes in each pair"/>
                                <TextBlock x:Name="TxtStride" Text="1" FontSize="8" Width="24"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="3,0,8,0"/>
                            </StackPanel>

                            <!-- Max Lag (autocorrelation: adjustable lag range) -->
                            <StackPanel x:Name="PanelMaxLag" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Max Lag:" FontSize="8" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                <Slider x:Name="SliderMaxLag" Width="70" Minimum="16" Maximum="1024"
                                        Value="256" IsSnapToTickEnabled="False"
                                        VerticalAlignment="Center"
                                        ValueChanged="SliderMaxLag_Changed"
                                        ToolTip="Maximum lag to compute autocorrelation for"/>
                                <TextBlock x:Name="TxtMaxLag" Text="256" FontSize="8" Width="32"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="3,0,8,0"/>
                            </StackPanel>

                            <!-- Scale (histogram/waveform: log vs linear) -->
                            <StackPanel x:Name="PanelScale" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Scale:" FontSize="8" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                <ComboBox x:Name="CboScale" Width="50" FontSize="8"
                                          VerticalAlignment="Center" SelectedIndex="0"
                                          SelectionChanged="CboScale_Changed">
                                    <ComboBoxItem Content="Log"/>
                                    <ComboBoxItem Content="Linear"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Scope (autocorrelation: full file vs selection vs per-region) -->
                            <StackPanel x:Name="PanelScope" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Scope:" FontSize="8" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,3,0"/>
                                <ComboBox x:Name="CboScope" Width="75" FontSize="8"
                                          VerticalAlignment="Center" SelectedIndex="0"
                                          SelectionChanged="CboScope_Changed">
                                    <ComboBoxItem Content="Full File"/>
                                    <ComboBoxItem Content="Selection"/>
                                    <ComboBoxItem Content="Per Region"/>
                                </ComboBox>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Row 2: tile overview and single-mode view share the same slot -->
                    <Grid Grid.Row="2">

                        <!-- ══ TILE OVERVIEW (default) ══════════════════════════════ -->
                        <ScrollViewer x:Name="TileScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="Visible">
                            <UniformGrid Columns="2" Margin="3">

                                <!-- Tile 0 — Byte-Pair Plot -->
                                <Border x:Name="TileBorder0" Tag="0" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg0" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Byte-Pair Plot" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 1 — Byte Histogram -->
                                <Border x:Name="TileBorder1" Tag="1" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg1" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Byte Histogram" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 2 — Position Heat Map -->
                                <Border x:Name="TileBorder2" Tag="2" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg2" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Position Heat Map" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 3 — Entropy Waveform -->
                                <Border x:Name="TileBorder3" Tag="3" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg3" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Entropy Waveform" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 4 — Parallel Coordinates -->
                                <Border x:Name="TileBorder4" Tag="4" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg4" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Parallel Coordinates" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 5 — RadViz -->
                                <Border x:Name="TileBorder5" Tag="5" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg5" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="RadViz" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 6 — Autocorrelation -->
                                <Border x:Name="TileBorder6" Tag="6" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg6" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Autocorrelation" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Tile 7 — Byte Presence -->
                                <Border x:Name="TileBorder7" Tag="7" Margin="2" Cursor="Hand"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Tile_Click">
                                    <Border.Style><Style TargetType="Border">
                                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#252535"/>
                                        </Trigger></Style.Triggers>
                                    </Style></Border.Style>
                                    <StackPanel>
                                        <Image x:Name="TileImg7" Height="110" Stretch="Uniform"
                                               Margin="3,3,3,1"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="Byte Presence" FontSize="9"
                                                   TextAlignment="Center" Margin="0,0,0,4"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                            </UniformGrid>
                        </ScrollViewer>

                        <!-- ══ SINGLE-MODE view (shown on tile click) ══════════════ -->
                        <Border x:Name="PlotContainer"
                                ClipToBounds="True" Margin="4,0,4,0"
                                Background="{StaticResource BackgroundBrush}"
                                Visibility="Collapsed"
                                MouseWheel="PlotContainer_MouseWheel"
                                MouseLeftButtonDown="PlotContainer_MouseDown"
                                MouseLeftButtonUp="PlotContainer_MouseUp"
                                MouseMove="PlotContainer_MouseMove"
                                MouseRightButtonUp="PlotContainer_RightClick"
                                Cursor="Cross">
                            <Grid>
                                <Image x:Name="DotPlotImage"
                                       Stretch="Fill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <!-- Rubber-band selection overlay -->
                                <Canvas x:Name="PlotSelCanvas" IsHitTestVisible="False">
                                    <Rectangle x:Name="PlotRubberBand"
                                               Stroke="#C0FFFFFF" StrokeThickness="1"
                                               StrokeDashArray="4,2"
                                               Fill="#1AFFFFFF"
                                               Visibility="Collapsed"
                                               Canvas.Left="0" Canvas.Top="0"
                                               Width="1" Height="1"/>
                                </Canvas>
                            </Grid>
                        </Border>

                    </Grid><!-- end shared row-1 Grid -->

                    <!-- Stats footer -->
                    <TextBlock x:Name="TxtDotPlotInfo" Grid.Row="3"
                               FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,3,0,5"
                               TextWrapping="Wrap"/>
                </Grid>

            </Grid>

        </Grid>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtFileInfo" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
