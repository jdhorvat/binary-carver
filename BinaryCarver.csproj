<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>BinaryCarver</RootNamespace>
    <AssemblyName>BinaryCarver</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <Version>1.0.0</Version>
    <Company>BinaryCarver</Company>
    <Product>BinaryCarver — Region Carving Workbench</Product>
  </PropertyGroup>

  <!-- Exclude reference materials from compilation — they're research/reference code only -->
  <ItemGroup>
    <Compile Remove="reference materials\**" />
    <None Remove="reference materials\**" />
    <Content Remove="reference materials\**" />
    <EmbeddedResource Remove="reference materials\**" />
    <Page Remove="reference materials\**" />
    <ApplicationDefinition Remove="reference materials\**" />
    <Resource Remove="reference materials\**" />
  </ItemGroup>

</Project>
